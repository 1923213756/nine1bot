{
  "name": "@nine1bot/platform-gitlab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts",
    "./runtime": "./src/runtime.ts",
    "./review": "./src/review/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "review:dry-run": "bun run scripts/review-dry-run.ts",
    "review:dry-run:webhook": "bun run scripts/review-dry-run.ts --webhook fixtures/review/sample-webhook-mr-note.json",
    "review:dry-run:runtime-output": "bun run scripts/review-dry-run.ts --webhook fixtures/review/sample-webhook-mr-note.json --runtime-output fixtures/review/sample-runtime-output.md",
    "review:dry-run:invalid-runtime-output": "bun run scripts/review-dry-run.ts --webhook fixtures/review/sample-webhook-mr-note.json --runtime-output fixtures/review/sample-invalid-runtime-output.md",
    "review:dry-run:subagents": "bun run scripts/review-dry-run.ts --webhook fixtures/review/sample-webhook-mr-note.json --subagent-outputs fixtures/review/sample-subagent-outputs.json"
  },
  "dependencies": {
    "@nine1bot/platform-protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "bun-types": "^1.3.11"
  }
}
